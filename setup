#!/bin/sh
# One-time per-machine install: puts the caw-new-project bootstrap skill in
# ~/.claude/skills so any Claude Code session can scaffold CAW projects by
# conversation. Idempotent; re-run after harness updates.
set -e
HERE="$(cd "$(dirname "$0")" && pwd)"
for RUNTIME in "$HOME/.claude/skills" "$HOME/.codex/skills"; do
  DEST="$RUNTIME/caw-new-project"
  mkdir -p "$DEST"
  sed "s|{{HARNESS_PATH}}|$HERE|g" \
    "$HERE/install/claude/caw-new-project/SKILL.md" > "$DEST/SKILL.md"
  echo "Installed: $DEST/SKILL.md (harness: $HERE)"
done
echo 'Try it in Claude Code: "Set up a new CAW project called my-app"'
"$HERE/.agents/scripts/forge.py" doctor 2>/dev/null || python3 "$HERE/.agents/scripts/forge.py" doctor || true
