{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "check:imports": "ts-node --project tsconfig.node.json linters/check-imports.ts",
    "check:boundaries": "ts-node --project tsconfig.node.json linters/check-boundaries.ts",
    "check:docs": "ts-node --project tsconfig.node.json linters/check-docs.ts",
    "check:all": "pnpm run check:imports && pnpm run check:boundaries && pnpm run check:docs",
    "generate:api-client": "./scripts/generate-api-client.sh",
    "db:migrate": "pnpm --filter api prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter api prisma migrate deploy",
    "db:seed": "pnpm --filter api prisma db seed",
    "db:studio": "pnpm --filter api prisma studio",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.2",
    "turbo": "^1.12.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.1.0"
}
