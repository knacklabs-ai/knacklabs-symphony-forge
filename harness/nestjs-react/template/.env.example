# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT={{PORT_BASE}}
WEB_PORT={{WEB_PORT}}

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT={{DB_PORT}}
DB_NAME={{PROJECT_NAME}}
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:{{DB_PORT}}/{{PROJECT_NAME}}?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT={{REDIS_PORT}}
REDIS_URL=redis://localhost:{{REDIS_PORT}}

# ── AWS Cognito ──────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_AUTHORITY=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRATION=1h

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:{{PORT_BASE}}
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_AUTHORITY=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX

# ── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:{{WEB_PORT}}
